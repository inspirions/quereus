{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@quereus/quereus": ["../quereus/src/index.ts"],
      "@quereus/quereus/parser": ["../quereus/src/parser/index.ts"]
    },
    "strict": true,
    "sourceMap": true,
    "types": ["node", "mocha"],
    "noEmit": true
  },
  "ts-node": {
    "esm": true,
    "experimentalSpecifierResolution": "node"
  },
  "include": ["test/**/*", "src/**/*"]
}
